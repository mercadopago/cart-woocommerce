# ============================================================================
# Docker Development Environment — Local Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================================

# Mercado Pago Credentials (required for payment testing)
# Get test credentials at: https://www.mercadopago.com/developers/panel/app
MP_PUBLIC_KEY_TEST=
MP_ACCESS_TOKEN_TEST=
MP_PUBLIC_KEY_PROD=
MP_ACCESS_TOKEN_PROD=

# Custom domain for notification_url (webhooks)
# Without this, notification_url may be null and MP API rejects payments.
# Set to your tunnel URL (without trailing slash):
#   MP_CUSTOM_DOMAIN=https://your-tunnel.trycloudflare.com
MP_CUSTOM_DOMAIN=

# ngrok static domain (only if using ngrok as tunnel)
# Get yours at: https://dashboard.ngrok.com/domains → "New Domain"
NGROK_DOMAIN=
